@page "/auction/{Id:int}"

@using AukcniSystem.Data
@using AukcniSystem.Entities
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore

@attribute [Authorize]
@rendermode InteractiveServer

@inject ApplicationDbContext Context
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav

<PageTitle>@(auction?.Title ?? "Detail aukce")</PageTitle>

<div class="container mt-4 pb-5">
    @if (auction == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Načítám detaily aukce...</p>
        </div>
    }
    else
    {
        @* Horní navigace *@
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Domů</a></li>
                <li class="breadcrumb-item"><a href="/categories/@auction.CategoryId">@auction.Category?.Name</a></li>
                <li class="breadcrumb-item active">@auction.Title</li>
            </ol>
        </nav>

        <div class="row">
            @* --- LEVÝ SLOUPCEC: Galerie a Popis --- *@
            <div class="col-lg-7">
                <div class="card border-0 shadow-sm mb-4">
                    <div class="p-3 text-center bg-light rounded-top">
                        <img src="@(string.IsNullOrEmpty(auction.ImagePath) ? "/images/no-image.png" : auction.ImagePath)"
                             class="img-fluid rounded"
                             style="max-height: 500px; object-fit: contain;" />
                    </div>
                    <div class="card-body">
                        <h2 class="fw-bold">@auction.Title</h2>
                        <div class="d-flex flex-wrap gap-2 mb-3">
                            <span class="badge bg-primary px-3 py-2">@auction.Category?.Name</span>
                            <span class="badge bg-light text-dark border px-3 py-2"><i class="bi bi-geo-alt"></i> @auction.Address</span>
                        </div>

                        <h5 class="fw-bold mt-4">Popis předmětu</h5>
                        <p class="text-secondary" style="white-space: pre-wrap; line-height: 1.6;">@auction.Description</p>

                        <div class="alert alert-secondary mt-4 d-flex align-items-center">
                            <i class="bi bi-person-circle fs-4 me-3"></i>
                            <div>
                                <small class="d-block text-muted">Vystavil prodejce:</small>
                                <strong>@auction.Seller?.UserName</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @* --- PRAVÝ SLOUPCEC: Příhozy a Stav --- *@
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm sticky-top" style="top: 2rem;">
                    <div class="card-body p-4">
                        @* Stavový indikátor a Cena *@
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <h6 class="text-uppercase text-muted small fw-bold mb-1">Aktuální cena</h6>
                                <h1 class="display-5 fw-bold @(IsCurrentUserWinning ? "text-success" : "text-primary") mb-0">
                                    @auction.CurrentPrice.ToString("N0") Kč
                                </h1>
                                @if (!IsExpired && IsCurrentUserWinning)
                                {
                                    <span class="badge bg-success mt-2 animate-pulse">
                                        <i class="bi bi-trophy-fill"></i> Aktuálně vyhráváte vy!
                                    </span>
                                }
                            </div>
                            <span class="badge @(IsExpired ? "bg-secondary" : "bg-danger") px-3 py-2">
                                @(IsExpired ? "Aukce skončila" : "Probíhá")
                            </span>
                        </div>

                        @if (!IsExpired)
                        {
                            @* Box s informacemi o příhozu *@
                            <div class="p-3 bg-light rounded-3 mb-4 border-start border-4 @(IsCurrentUserWinning ? "border-success" : "border-primary")">
                                <div class="d-flex justify-content-between mb-2 text-muted small">
                                    <span>Minimální krok:</span>
                                    <span>@(auction.IsPercentageStep ? $"{auction.MinStepValue} %" : $"{auction.MinStepValue} Kč")</span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="fw-bold text-dark">Váš příhoz musí být alespoň:</span>
                                    <span class="text-success fw-bold">@CalculateNextMinBid().ToString("N0") Kč</span>
                                </div>
                            </div>

                            @if (auction.SellerId == currentUserId)
                            {
                                <div class="alert alert-info border-0 shadow-sm mb-0">
                                    <i class="bi bi-info-circle-fill me-2"></i>
                                    <strong>Toto je vaše aukce.</strong><br />
                                    <small>Jako prodejce nemůžete navyšovat vlastní cenu.</small>
                                </div>
                            }
                            else
                            {
                                <AuthorizeView Roles="Klient">
                                    <Authorized>
                                        <div class="mb-3">
                                            <label class="form-label fw-bold small">Vaše maximální nabídka</label>
                                            <div class="input-group input-group-lg mb-2">
                                                <input type="number" class="form-control @(IsCurrentUserWinning ? "border-success" : "")"
                                                       @bind="bidAmount" min="@CalculateNextMinBid()" />
                                                <span class="input-group-text">Kč</span>
                                            </div>
                                            <button class="btn @(IsCurrentUserWinning ? "btn-outline-success border-2" : "btn-success") btn-lg w-100 fw-bold py-3 shadow-sm"
                                                    @onclick="PlaceBid">
                                                @(IsCurrentUserWinning ? "NAVÝŠIT SVŮJ VÍTĚZNÝ PŘÍHOZ" : "PŘIHODIT NYNÍ")
                                            </button>
                                        </div>

                                        <div class="text-center">
                                            <small class="text-muted">Váš zůstatek: <strong>@currentUserBalance.ToString("N0") Kč</strong></small>
                                        </div>
                                    </Authorized>
                                </AuthorizeView>
                            }
                        }
                        else
                        {
                            <div class="alert alert-dark text-center mb-0 shadow-sm">
                                <i class="bi bi-lock-fill me-2"></i>
                                <strong>Aukce uzavřena</strong>
                            </div>
                            @if (HighestBid != null)
                            {
                                <div class="text-center mt-3 p-3 bg-success bg-opacity-10 rounded">
                                    <div class="text-success small fw-bold">VÍTĚZ AUKCE</div>
                                    <h4 class="fw-bold mb-0 text-success">@HighestBid.Bidder?.UserName</h4>
                                    <div class="text-muted small">Konečná cena: @auction.CurrentPrice.ToString("N0") Kč</div>
                                </div>
                            }
                        }

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger mt-3 mb-0">@errorMessage</div>
                        }
                        @if (!string.IsNullOrEmpty(successMessage))
                        {
                            <div class="alert alert-success mt-3 mb-0">@successMessage</div>
                        }
                    </div>
                </div>

                @* Historie příhozů *@
                <div class="card border-0 shadow-sm mt-4">
                    <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold"><i class="bi bi-list-ul me-2"></i>Historie příhozů</h6>
                        <span class="badge bg-light text-dark border">@auction.Bids.Count příhozů</span>
                    </div>
                    <div class="card-body p-0 overflow-auto" style="max-height: 400px;">
                        <ul class="list-group list-group-flush">
                            @foreach (var bid in auction.Bids.OrderByDescending(b => b.BidTime))
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3 @(bid.BidderId == currentUserId ? "bg-light" : "")">
                                    <div>
                                        <div class="fw-bold @(bid == HighestBid ? "text-success" : "text-primary")">
                                            @bid.NewPrice.ToString("N0") Kč
                                            @if (bid == HighestBid && !IsExpired)
                                            {
                                                <small class="ms-1 badge bg-success p-1">Vede</small>
                                            }
                                        </div>
                                        <small class="text-muted">@bid.Bidder?.UserName</small>
                                    </div>
                                    <div class="text-end">
                                        <small class="d-block text-muted small">@bid.BidTime.ToString("dd.MM.yyyy")</small>
                                        <small class="d-block text-muted" style="font-size: 0.75rem;">@bid.BidTime.ToString("HH:mm:ss")</small>
                                    </div>
                                </li>
                            }
                            @if (!auction.Bids.Any())
                            {
                                <li class="list-group-item text-center py-4 text-muted small italic">Zatím nebyly podány žádné nabídky.</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .sticky-top {
        z-index: 100;
    }

    .animate-pulse {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            opacity: 1;
        }

        50% {
            opacity: 0.6;
        }

        100% {
            opacity: 1;
        }
    }

    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
</style>

@code {
    [Parameter] public int Id { get; set; }

    private Auction? auction;
    private decimal bidAmount;
    private decimal currentUserBalance;
    private string errorMessage = "";
    private string successMessage = "";
    private string? currentUserId;

    // Pomocné vlastnosti pro zobrazení vítěze
    private Bid? HighestBid => auction?.Bids.OrderByDescending(b => b.NewPrice).FirstOrDefault();
    private bool IsCurrentUserWinning => HighestBid != null && HighestBid.BidderId == currentUserId;

    private bool IsExpired => auction?.ApprovedAt.HasValue == true &&
                             auction.ApprovedAt.Value.AddHours(auction.DurationHours) < DateTime.Now;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    private async Task RefreshData()
    {
        auction = await Context.Auctions
            .Include(a => a.Category)
            .Include(a => a.Seller)
            .Include(a => a.Bids)
            .ThenInclude(b => b.Bidder)
            .FirstOrDefaultAsync(a => a.Id == Id);

        if (auction != null)
        {
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = await UserManager.GetUserAsync(authState.User);

            if (user != null)
            {
                currentUserId = user.Id;
                currentUserBalance = user.VirtualBalance;
            }

            bidAmount = CalculateNextMinBid();
        }
    }

    private decimal CalculateNextMinBid()
    {
        if (auction == null) return 0;
        if (auction.IsPercentageStep)
        {
            decimal step = auction.CurrentPrice * (auction.MinStepValue / 100m);
            return Math.Ceiling(auction.CurrentPrice + step);
        }
        return auction.CurrentPrice + auction.MinStepValue;
    }

    private async Task PlaceBid()
    {
        errorMessage = "";
        successMessage = "";

        if (auction == null || IsExpired) return;

        var authState = await AuthProvider.GetAuthenticationStateAsync();
        var userId = UserManager.GetUserId(authState.User);

        // Načtení aktuálního uživatele (toho, kdo teď přihazuje)
        var user = await Context.Users.FindAsync(userId);

        if (user == null) return;
        if (user.VirtualBalance < bidAmount)
        {
            errorMessage = "Nedostatečný zůstatek na virtuálním účtu.";
            return;
        }

        using var transaction = await Context.Database.BeginTransactionAsync();
        try
        {
            // 1. Získání čerstvých dat aukce a POSLEDNÍHO příhozu
            var freshAuction = await Context.Auctions
                .Include(a => a.Bids)
                .ThenInclude(b => b.Bidder)
                .FirstOrDefaultAsync(a => a.Id == Id);

            if (freshAuction == null || bidAmount <= freshAuction.CurrentPrice)
            {
                errorMessage = "Příhoz musí být vyšší než aktuální cena.";
                await transaction.RollbackAsync();
                return;
            }

            // --- LOGIKA VRÁCENÍ PENĚZ ---
            // Najdeme poslední příhoz před tímto novým
            var lastBid = freshAuction.Bids.OrderByDescending(b => b.NewPrice).FirstOrDefault();

            if (lastBid != null)
            {
                // VRÁCENÍ PENĚZ: Předchozímu zájemci vrátíme celou částku, kterou tam měl "zablokovanou"
                var previousBidder = lastBid.Bidder;
                if (previousBidder != null)
                {
                    previousBidder.VirtualBalance += lastBid.NewPrice;
                    Context.Users.Update(previousBidder);
                }
            }

            // --- ODEČTENÍ PENĚZ NOVÉMU ZÁJEMCI ---
            user.VirtualBalance -= bidAmount;
            Context.Users.Update(user);

            // 2. Vytvoření nového příhozu
            var newBid = new Bid
            {
                AuctionId = Id,
                BidderId = user.Id,
                NewPrice = bidAmount,
                BidAmount = bidAmount - freshAuction.CurrentPrice,
                BidTime = DateTime.Now
            };

            freshAuction.CurrentPrice = bidAmount;
            Context.Bids.Add(newBid);
            Context.Auctions.Update(freshAuction);

            // 3. Uložení všeho najednou
            await Context.SaveChangesAsync();
            await transaction.CommitAsync();

            successMessage = "Příhoz byl úspěšně proveden a předchozímu zájemci byly vráceny prostředky.";
            await RefreshData();
        }
        catch (Exception ex)
        {
            await transaction.RollbackAsync();
            errorMessage = "Chyba při zpracování příhozu: " + ex.Message;
        }
    }
}