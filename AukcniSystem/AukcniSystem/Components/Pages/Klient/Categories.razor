@page "/categories/{CategoryId:int?}"
@using AukcniSystem.Data
@using AukcniSystem.Entities
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext Context
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="container mt-4">
    @if (CategoryId == null)
    {
        <h2 class="mb-4 text-primary fw-bold">Procházet kategorie</h2>
        <div class="row g-4">
            @foreach (var cat in allCategories)
            {
                <div class="col-md-4">
                    @* OPRAVA: Použití jednoduchých uvozovek pro atribut a explicitní lambda *@
                    <div class="card h-100 shadow-sm border-0 hover-card"
                         @onclick='(() => NavigateToCategory(cat.Id))'
                         style="cursor: pointer;">
                        <div class="card-body d-flex justify-content-between align-items-center">
                            <div>
                                <h5 class="mb-0 fw-bold">@cat.Name</h5>
                                <small class="text-muted">
                                    Aktivních: @cat.Auctions.Count(a => a.IsApproved && !a.IsDeleted)
                                </small>
                            </div>
                            <i class="bi bi-chevron-right text-primary"></i>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/categories">Kategorie</a></li>
                <li class="breadcrumb-item active">@currentCategory?.Name</li>
            </ol>
        </nav>

        <div class="row">
            <aside class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm p-3 sticky-top" style="top: 20px;">
                    <h5 class="fw-bold mb-3"><i class="bi bi-filter"></i> Filtrování</h5>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Řazení</label>
                        <select class="form-select form-select-sm" @onchange="HandleSortChange">
                            <option value="newest">Nejnovější</option>
                            <option value="oldest">Nejstarší</option>
                            <option value="ending_soon">Končící brzy</option>
                            <option value="popular">Nejoblíbenější</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Minimální příhoz</label>
                        @* OPRAVA: Onchange volá metodu bez parametrů nebo s ChangeEventArgs *@
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="minStep" checked
                                   @onchange='(() => UpdateStepFilter("all"))'>
                            <label class="form-check-label small">Všechny</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="minStep"
                                   @onchange='(() => UpdateStepFilter("czk"))'>
                            <label class="form-check-label small">Fixní (CZK)</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="minStep"
                                   @onchange='(() => UpdateStepFilter("percent"))'>
                            <label class="form-check-label small">Procentuální (%)</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-bold">Doba trvání</label>
                        <select class="form-select form-select-sm" @onchange="HandleDurationChange">
                            <option value="0">Libovolná</option>
                            <option value="24">Do 24 hodin</option>
                            <option value="168">Do 7 dnů</option>
                        </select>
                    </div>
                </div>
            </aside>

            <main class="col-lg-9">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="fw-bold mb-0">@currentCategory?.Name</h3>
                    <span class="badge bg-light text-dark border">Nalezeno: @filteredAuctions.Count</span>
                </div>

                <div class="row g-3">
                    @foreach (var a in filteredAuctions)
                    {
                        <div class="col-md-6">
                            <div class="card h-100 border-0 shadow-sm auction-card">
                                <div class="row g-0 h-100">
                                    <div class="col-4">
                                        <img src="@(string.IsNullOrEmpty(a.ImagePath) ? "/no-img.png" : a.ImagePath)"
                                             class="img-fluid rounded-start h-100" style="object-fit: cover;">
                                    </div>
                                    <div class="col-8">
                                        <div class="card-body p-3">
                                            <h6 class="fw-bold mb-1">@a.Title</h6>
                                            <div class="text-primary fw-bold mb-1">@a.CurrentPrice.ToString("N0") Kč</div>
                                            <a href="/auction/@a.Id" class="btn btn-sm btn-outline-primary w-100 mt-2">Detail</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </main>
        </div>
    }
</div>

@code {
    [Parameter] public int? CategoryId { get; set; }

    private List<Category> allCategories = new();
    private Category? currentCategory;
    private List<Auction> filteredAuctions = new();

    private string sortBy = "newest";
    private string stepFilter = "all";
    private int durationFilter = 0;

    protected override async Task OnParametersSetAsync()
    {
        if (CategoryId == null)
        {
            allCategories = await Context.Categories.Include(c => c.Auctions).ToListAsync();
        }
        else
        {
            currentCategory = await Context.Categories
                .Include(c => c.Auctions.Where(a => a.IsApproved && !a.IsDeleted))
                .ThenInclude(a => a.Bids)
                .FirstOrDefaultAsync(c => c.Id == CategoryId);

            ApplyFilters();
        }
    }

    private void NavigateToCategory(int id) => Nav.NavigateTo($"/categories/{id}");

    private void HandleSortChange(ChangeEventArgs e)
    {
        sortBy = e.Value?.ToString() ?? "newest";
        ApplyFilters();
    }

    private void HandleDurationChange(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int val)) durationFilter = val;
        ApplyFilters();
    }

    private void UpdateStepFilter(string val)
    {
        stepFilter = val;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        if (currentCategory == null) return;
        var query = currentCategory.Auctions.AsEnumerable();

        if (durationFilter > 0)
            query = query.Where(a => (a.ApprovedAt.Value.AddHours(a.DurationHours) - DateTime.Now).TotalHours <= durationFilter);

        if (stepFilter == "czk") query = query.Where(a => !a.IsPercentageStep);
        if (stepFilter == "percent") query = query.Where(a => a.IsPercentageStep);

        query = sortBy switch
        {
            "oldest" => query.OrderBy(a => a.ApprovedAt),
            "ending_soon" => query.OrderBy(a => a.ApprovedAt.Value.AddHours(a.DurationHours)),
            "popular" => query.OrderByDescending(a => a.Bids.Count),
            _ => query.OrderByDescending(a => a.ApprovedAt)
        };

        filteredAuctions = query.ToList();
    }
}